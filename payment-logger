<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Log Payment</title>
<style>
  :root {
    --teal: #0E6E72;
    --teal-dark: #0A5256;
    --teal-light: #E6F1F1;
    --ink: #1A2424;
    --muted: #6B7A7A;
    --paper: #FBFAF7;
    --line: #DDE6E5;
    --error: #B3413C;
    --radius: 14px;
  }

  * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
    height: 100%;
    overscroll-behavior-y: contain;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  }

  header {
    padding: 28px 24px 18px;
    border-bottom: 1px solid var(--line);
  }

  header .eyebrow {
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    font-weight: 600;
    margin: 0 0 4px;
  }

  header h1 {
    font-size: 24px;
    margin: 0;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  main {
    flex: 1;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }

  .field-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 10px;
    display: block;
  }

  .source-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .source-btn {
    border: 1.5px solid var(--line);
    background: #fff;
    border-radius: var(--radius);
    padding: 20px 12px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, transform 0.1s ease;
    user-select: none;
  }

  .source-btn:active { transform: scale(0.97); }

  .source-btn .name {
    font-size: 17px;
    font-weight: 700;
    display: block;
  }

  .source-btn .currency {
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
    display: block;
  }

  .source-btn.selected {
    border-color: var(--teal);
    background: var(--teal-light);
  }

  .source-btn.selected .name { color: var(--teal-dark); }

  .amount-row {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    padding: 4px 18px;
    transition: border-color 0.15s ease;
  }

  .amount-row:focus-within { border-color: var(--teal); }

  .amount-row .symbol {
    font-size: 22px;
    font-weight: 700;
    color: var(--muted);
    margin-right: 8px;
    min-width: 28px;
  }

  .amount-row input[type="number"] {
    border: none;
    outline: none;
    background: transparent;
    font-size: 28px;
    font-weight: 700;
    width: 100%;
    padding: 16px 0;
    color: var(--ink);
    font-family: inherit;
  }

  input[type="text"] {
    width: 100%;
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 14px 16px;
    font-size: 16px;
    font-family: inherit;
    background: #fff;
    outline: none;
    transition: border-color 0.15s ease;
  }

  input[type="text"]:focus { border-color: var(--teal); }

  .submit-btn {
    border: none;
    background: var(--teal);
    color: #fff;
    font-size: 17px;
    font-weight: 700;
    padding: 18px;
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.15s ease, transform 0.1s ease;
    margin-top: 4px;
  }

  .submit-btn:active { transform: scale(0.98); }
  .submit-btn:disabled { background: #B8C7C6; cursor: not-allowed; }

  .status {
    border-radius: var(--radius);
    padding: 16px 18px;
    font-size: 14px;
    line-height: 1.5;
    display: none;
  }

  .status.show { display: block; }

  .status.success {
    background: var(--teal-light);
    color: var(--teal-dark);
    border: 1px solid var(--teal);
  }

  .status.error {
    background: #FBEAE9;
    color: var(--error);
    border: 1px solid var(--error);
  }

  .status .big {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 2px;
    display: block;
  }

  .setup-screen {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
    justify-content: center;
  }

  .setup-screen h2 { font-size: 19px; margin: 0 0 4px; }
  .setup-screen p { font-size: 14px; color: var(--muted); line-height: 1.5; margin: 0; }

  footer {
    padding: 16px 24px 28px;
    text-align: center;
  }

  footer button {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 12px;
    text-decoration: underline;
    cursor: pointer;
    font-family: inherit;
  }

  .hidden { display: none !important; }

  .recent {
    font-size: 13px;
    color: var(--muted);
    text-align: center;
  }
</style>
</head>
<body>

  <div id="setupScreen" class="setup-screen hidden">
    <h2>One-time setup</h2>
    <p>Paste your Apps Script Web App URL (the one ending in <code>/exec</code>) and the secret key you set in the script. Both are saved on this device only — never uploaded anywhere.</p>
    <input type="text" id="setupUrl" placeholder="https://script.google.com/macros/s/.../exec">
    <input type="text" id="setupKey" placeholder="Secret key (same as in your script)">
    <button class="submit-btn" id="saveUrlBtn">Save & continue</button>
  </div>

  <div id="mainScreen" class="hidden" style="display:flex; flex-direction:column; flex:1;">
    <header>
      <p class="eyebrow">Hisaab</p>
      <h1>Log a payment</h1>
    </header>

    <main>
      <div>
        <span class="field-label">Source</span>
        <div class="source-grid">
          <div class="source-btn" data-source="Upwork" data-currency="USD">
            <span class="name">Upwork</span>
            <span class="currency">USD</span>
          </div>
          <div class="source-btn" data-source="Haider" data-currency="AUD">
            <span class="name">Haider</span>
            <span class="currency">AUD</span>
          </div>
        </div>
      </div>

      <div>
        <span class="field-label">Amount</span>
        <div class="amount-row">
          <span class="symbol" id="currencySymbol">$</span>
          <input type="number" id="amountInput" inputmode="decimal" placeholder="0.00" step="0.01">
        </div>
      </div>

      <div>
        <span class="field-label">Notes (optional)</span>
        <input type="text" id="notesInput" placeholder="e.g. Invoice #214">
      </div>

      <button class="submit-btn" id="submitBtn" disabled>Log payment</button>

      <div class="status" id="statusBox"></div>
    </main>

    <footer>
      <button id="changeUrlBtn">Change URL / secret key</button>
    </footer>
  </div>

<script>
(function() {
  const STORAGE_KEY = 'hisaab_apps_script_url';
  const STORAGE_KEY_SECRET = 'hisaab_apps_script_secret';
  const setupScreen = document.getElementById('setupScreen');
  const mainScreen = document.getElementById('mainScreen');
  const setupUrlInput = document.getElementById('setupUrl');
  const setupKeyInput = document.getElementById('setupKey');
  const saveUrlBtn = document.getElementById('saveUrlBtn');
  const changeUrlBtn = document.getElementById('changeUrlBtn');
  const sourceButtons = document.querySelectorAll('.source-btn');
  const amountInput = document.getElementById('amountInput');
  const notesInput = document.getElementById('notesInput');
  const submitBtn = document.getElementById('submitBtn');
  const statusBox = document.getElementById('statusBox');
  const currencySymbol = document.getElementById('currencySymbol');

  let selectedSource = null;
  let selectedCurrency = null;

  function getUrl() { return localStorage.getItem(STORAGE_KEY); }
  function getKey() { return localStorage.getItem(STORAGE_KEY_SECRET); }

  function showMain() {
    setupScreen.classList.add('hidden');
    mainScreen.classList.remove('hidden');
  }

  function showSetup() {
    mainScreen.classList.add('hidden');
    setupScreen.classList.remove('hidden');
    setupUrlInput.value = getUrl() || '';
    setupKeyInput.value = getKey() || '';
  }

  if (getUrl() && getKey()) { showMain(); } else { showSetup(); }

  saveUrlBtn.addEventListener('click', function() {
    const val = setupUrlInput.value.trim();
    const key = setupKeyInput.value.trim();
    if (!val.startsWith('https://script.google.com/')) {
      alert('That doesn\'t look like an Apps Script URL. It should start with https://script.google.com/ and end with /exec');
      return;
    }
    if (!key) {
      alert('Enter the secret key you set in your Apps Script (the SECRET_KEY value).');
      return;
    }
    localStorage.setItem(STORAGE_KEY, val);
    localStorage.setItem(STORAGE_KEY_SECRET, key);
    showMain();
  });

  changeUrlBtn.addEventListener('click', showSetup);

  function updateSubmitState() {
    const amount = parseFloat(amountInput.value);
    submitBtn.disabled = !(selectedSource && amount > 0);
  }

  sourceButtons.forEach(btn => {
    btn.addEventListener('click', function() {
      sourceButtons.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedSource = btn.dataset.source;
      selectedCurrency = btn.dataset.currency;
      currencySymbol.textContent = selectedCurrency === 'AUD' ? 'A$' : '$';
      updateSubmitState();
    });
  });

  amountInput.addEventListener('input', updateSubmitState);

  function showStatus(type, big, small) {
    statusBox.className = 'status show ' + type;
    statusBox.innerHTML = '<span class="big">' + big + '</span>' + (small || '');
  }

  submitBtn.addEventListener('click', function() {
    const url = getUrl();
    const amount = amountInput.value;
    const notes = notesInput.value;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Logging…';
    statusBox.className = 'status';

    const params = new URLSearchParams();
    params.append('key', getKey());
    params.append('source', selectedSource);
    params.append('currency', selectedCurrency);
    params.append('amount', amount);
    params.append('notes', notes);

    fetch(url, {
      method: 'POST',
      body: params
    })
    .then(r => r.json())
    .then(data => {
      submitBtn.textContent = 'Log payment';
      if (data.status === 'success') {
        const pkrText = data.pkrAmount ? ('≈ Rs.' + Math.round(data.pkrAmount).toLocaleString()) : '';
        showStatus('success', 'Logged: ' + selectedCurrency + ' ' + amount + ' from ' + selectedSource, pkrText);
        amountInput.value = '';
        notesInput.value = '';
        sourceButtons.forEach(b => b.classList.remove('selected'));
        selectedSource = null;
        updateSubmitState();
      } else {
        showStatus('error', 'Something went wrong', data.message || 'Check the sheet and try again.');
        submitBtn.disabled = false;
      }
    })
    .catch(err => {
      submitBtn.textContent = 'Log payment';
      showStatus('error', 'Couldn\'t reach the sheet', 'Check your internet connection and try again.');
      submitBtn.disabled = false;
    });
  });
})();
</script>

</body>
</html>
